---
const nav = [
  { label: '作品', href: '/' },
  { label: '关于我', href: '/#about' },
  { label: '其他', href: '/#otherworks' },
  { label: '联系', href: '/#contact' },
];
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-colors duration-300">
  <nav class="flex items-center justify-between px-8 lg:px-12 py-6">
    <a
      href="/"
      class="text-base uppercase tracking-[0.2em] font-medium transition-colors duration-300"
    >
      XUJINGYI
    </a>
    <ul class="flex items-center gap-8">
      {nav.map((item) => (
        <li>
          <a
            href={item.href}
            class="text-base uppercase tracking-[0.15em] transition-colors duration-300 relative group/link"
          >
            {item.label}
            <span class="absolute left-0 bottom-0 w-0 h-[1px] bg-current transition-all duration-300 group-hover/link:w-full"></span>
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  #site-header {
    color: white;
    background: transparent;
    transition: background 0.5s ease, color 0.5s ease, border-color 0.5s ease;
  }
  #site-header.scrolled {
    color: #0A0A0A;
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }
  #site-header.scrolled a {
    color: #0A0A0A;
  }
  #site-header.scrolled a:hover {
    opacity: 0.5;
  }
  /* desktop: keep transparent with white text */
  @media (min-width: 768px) {
    #site-header {
      mix-blend-mode: difference;
    }
    #site-header.scrolled {
      mix-blend-mode: normal;
    }
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const onScroll = () => {
    header.classList.toggle('scrolled', window.scrollY > window.innerHeight * 0.4);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
