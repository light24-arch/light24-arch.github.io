/* ── Grid span ── */
function gridSpan(v: Award['variant']): string {
  switch (v) {
    case 'hero':  return 'md:col-span-2 md:row-span-2';
    case 'wide':  return 'md:col-span-2 md:row-span-1';
    case 'tall':  return 'md:col-span-1 md:row-span-2';
    case 'small': return 'md:col-span-1 md:row-span-1';
  }
}

/* ── Front-face label colour by bg ── */
function labelColor(bg: string): string {
  return bg === 'bg-arch-4' ? 'text-arch-1/70' : 'text-arch-3/80';
}

/* ── Front title colour by bg ── */
function titleColor(bg: string): string {
  return bg === 'bg-arch-4' ? 'text-arch-0' : 'text-arch-4';
}

/* ── Architecture side-label colour ── */
function sideLabelColor(bg: string): string {
  return bg === 'bg-arch-4' ? 'text-arch-1/50' : 'text-arch-3/40';
}
---

<div class="w-full max-w-[1400px] mx-auto grid grid-cols-1 md:grid-cols-6 grid-rows-none md:grid-rows-3 gap-3 md:gap-5 auto-rows-[260px] md:auto-rows-[1fr] md:aspect-[2/1]">
  {
    awards.map((a, i) => {
      const hasImg = !!a.img;
      const cardClasses = `group/card relative overflow-hidden ${a.bg} rounded-[2rem] transition-all duration-500 hover:shadow-2xl hover:scale-[1.02] shadow-md border border-arch-2/15 flex flex-col justify-between ${hasImg ? '' : 'p-5 md:p-7'} ${gridSpan(a.variant)}`;
      const inner = (
        <>
          {/* ── Mobile tap toggle (hidden on desktop) ── */}
          <input type="checkbox" class="peer/tap absolute inset-0 z-30 opacity-0 cursor-pointer md:hidden" />

          {/* ══════ B&W image at card level (outside padded front-face) ══════ */}
          {hasImg && (
            <>
              <img src={a.img} alt={a.title} class="absolute inset-0 w-full h-full object-cover grayscale" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent pointer-events-none" />
            </>
          )}

          {/* ── Front face ── */}
          <div class={`relative z-10 h-full flex flex-col justify-between peer-checked/tap:opacity-0 transition-opacity duration-400 ${hasImg ? 'p-4 md:p-5' : ''}`}>
            {a.img ? (
              /* Text with blur backdrop for image cards */
              <div class="mt-auto p-3">
                <p class="text-white/70 text-[10px] font-bold tracking-[0.2em] uppercase mb-1">{a.year}</p>
                {a.variant === 'hero' ? (
                  <div>
                    {a.subtitle ? <p class="text-white/60 text-xs font-bold tracking-widest uppercase mb-1">{a.subtitle}</p> : null}
                    <h2 class="text-2xl lg:text-4xl font-black tracking-tighter leading-none text-white">{a.title}</h2>
                  </div>
                ) : a.variant === 'wide' ? (
                  <h2 class="text-xl lg:text-2xl font-black tracking-tight leading-none text-white">{a.title}</h2>
                ) : (
                  <h2 class="text-lg leading-none font-black tracking-tight text-white" set:html={a.title} />
                )}
              </div>
            ) : (
              <>
                <p class={`text-[10px] font-bold tracking-[0.2em] uppercase ${labelColor(a.bg)}`}>{a.year}</p>
                {
                  a.variant === 'hero' ? (
                    <div>
                      {a.subtitle ? <p class={`text-xs font-bold tracking-widest uppercase mb-2 ${labelColor(a.bg)}`}>{a.subtitle}</p> : null}
                      <h2 class={`text-4xl lg:text-6xl font-black tracking-tighter leading-none ${titleColor(a.bg)}`}>{a.title}</h2>
                    </div>
                  ) : a.variant === 'wide' ? (
                    <div class="flex justify-between items-end w-full">
                      <h2 class={`text-2xl lg:text-3xl font-black tracking-tight leading-none ${titleColor(a.bg)}`}>{a.title}</h2>
                      <span class={`text-sm font-bold uppercase tracking-widest ${sideLabelColor(a.bg)}`}>Architecture</span>
                    </div>
                  ) : (
                    <h2 class={`text-2xl leading-none font-black tracking-tight ${titleColor(a.bg)}`} set:html={a.title} />
                  )
                }
              </>
            )}
          </div>

          {/* ── Curtain overlay (color image slides up from bottom) ── */}
          <div
            class={`absolute inset-0 z-20 translate-y-full group-hover/card:translate-y-0 peer-checked/tap:translate-y-0 transition-transform duration-700 ease-[cubic-bezier(0.22,1,0.36,1)]`}
          >
            {a.img ? (
              <>
                {/* Color image (no grayscale) */}
                <img src={a.img} alt={a.title} class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-black/20 backdrop-blur-[2px]" />
                <div class="absolute inset-x-0 bottom-0 p-4 md:p-5">
                  {a.variant === 'hero' ? (
                    <>
                      <span class={`inline-block px-3 py-1 ${a.badgeBg} text-arch-0 text-[10px] font-bold uppercase tracking-widest rounded-full w-max mb-4`}>{a.level}</span>
                      <h3 class="text-white text-xl lg:text-2xl font-bold leading-tight mb-4">{a.project}</h3>
                      <div class="w-full h-[1px] bg-white/20 mb-4"></div>
                      <p class="text-white/70 text-sm font-light">负责：{a.role}</p>
                    </>
                  ) : a.variant === 'wide' ? (
                    <>
                      <span class="text-white/60 text-[10px] font-bold tracking-widest uppercase mb-1">{a.level}</span>
                      <h3 class="text-white text-lg font-bold leading-tight">{a.project}</h3>
                      {a.id === 6 ? <p class="text-white/70 text-xs font-light mt-2">{a.role}</p> : null}
                    </>
                  ) : a.variant === 'tall' ? (
                    <>
                      <span class="text-white/60 text-[10px] font-bold tracking-widest uppercase mb-2">{a.level}</span>
                      <h3 class="text-white text-sm font-bold leading-snug mb-4">{a.project}</h3>
                      <p class="text-white/70 text-xs font-light">{a.role}</p>
                    </>
                  ) : (
                    <>
                      <span class="text-white/60 text-[9px] font-bold tracking-widest uppercase mb-1">{a.level}</span>
                      <h3 class="text-white text-[11px] font-bold leading-tight mb-2 line-clamp-3">{a.project}</h3>
                      <p class="text-white/70 text-[9px]">{a.role}</p>
                    </>
                  )}
                </div>
              </>
            ) : (
              <div class={`absolute inset-0 ${a.curtainBg} p-5 md:p-7 flex flex-col justify-end`}>
                {a.variant === 'hero' ? (
                  <>
                    <span class={`inline-block px-3 py-1 ${a.badgeBg} text-arch-0 text-[10px] font-bold uppercase tracking-widest rounded-full w-max mb-4`}>{a.level}</span>
                    <h3 class={`${a.curtainText} text-xl lg:text-2xl font-bold leading-tight mb-4`}>{a.project}</h3>
                    <div class="w-full h-[1px] bg-arch-0/15 mb-4"></div>
                    <p class={`${a.curtainMuted} text-sm font-light`}>负责：{a.role}</p>
                  </>
                ) : a.variant === 'wide' ? (
                  <>
                    <span class={`${a.curtainMuted} text-[10px] font-bold tracking-widest uppercase mb-1`}>{a.level}</span>
                    <h3 class={`${a.curtainText} text-lg font-bold leading-tight`}>{a.project}</h3>
                    {a.id === 6 ? <p class={`${a.curtainMuted} text-xs font-light mt-2`}>{a.role}</p> : null}
                  </>
                ) : a.variant === 'tall' ? (
                  <>
                    <span class={`${a.curtainMuted} text-[10px] font-bold tracking-widest uppercase mb-2`}>{a.level}</span>
                    <h3 class={`${a.curtainText} text-sm font-bold leading-snug mb-4`}>{a.project}</h3>
                    <p class={`${a.curtainMuted} text-xs font-light`}>{a.role}</p>
                  </>
                ) : (
                  <>
                    <span class={`${a.curtainMuted} text-[9px] font-bold tracking-widest uppercase mb-1`}>{a.level}</span>
                    <h3 class={`${a.curtainText} text-[11px] font-bold leading-tight mb-2 line-clamp-3`}>{a.project}</h3>
                    <p class={`${a.curtainMuted} text-[9px]`}>{a.role}</p>
                  </>
                )}
              </div>
            )}
          </div>
      </>
    );
    return a.link ? (
      <a href={a.link} class={cardClasses}>{inner}</a>
    ) : (
      <div class={cardClasses}>{inner}</div>
    );
  })}
</div>

