---
interface Award {
  id: number;
  year: string;
  title: string;
  subtitle: string;
  level: string;
  project: string;
  role: string;
  variant: 'hero' | 'wide' | 'tall' | 'small';
  /** Card background colour from arch palette */
  bg: string;
  /** Overlay bg (glass curtain) */
  curtainBg: string;
  /** Overlay text colour */
  curtainText: string;
  /** Overlay muted colour */
  curtainMuted: string;
  /** Badge bg for hero overlay */
  badgeBg: string;
  /** Link to project/artwork detail page */
  link?: string;
  /** Competition image (B&W → color on hover) */
  img?: string;
}

