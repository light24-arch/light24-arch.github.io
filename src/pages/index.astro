---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import HeroCarousel from '../components/HeroCarousel';
import TextReveal from '../components/TextReveal';
import FadeIn from '../components/FadeIn';
import ProjectCard from '../components/ProjectCard';
import OtherWorksFanOut from '../components/OtherWorksFanOut';
import AboutSection from '../components/AboutSection.astro';
import ProjectMap from '../components/ProjectMap';
import AwardsBento from '../components/AwardsBento.astro';
import { categoryLabel, statusLabel } from '../utils/labels';
import { parseArtworkItems } from '../utils/schema';

const allProjects = await getCollection('projects');
const projects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)

const allArtworks = await getCollection('artwork');
const artworks = allArtworks
  .filter((a) => a.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const fanOutItems = parseArtworkItems(
  artworks.map((art) => ({
    title: art.data.title,
    hero: art.data.hero,
    medium: art.data.medium,
    year: art.data.year,
    slug: art.slug,
  })),
);

// Hero 轮播精选：按 order 值指定展示项目
const CAROUSEL_ORDERS = [2, 3, 5, 6];
const carouselSlides = projects.filter((p) => CAROUSEL_ORDERS.includes(p.data.order)).map((p) => ({
  image: p.data.hero,
  title: p.data.title,
  href: `/projects/${p.slug}`,
}));

// 项目地图数据
const mapProjects = allProjects
  .filter((p) => p.data.coordinates != null)
  .map((p) => ({
    slug: p.slug,
    title: p.data.title,
    location: p.data.location,
    year: p.data.year,
    hero: p.data.hero,
    coordinates: p.data.coordinates!,
  }));

---

<Base
  title="首页"
  description="林 — 建筑·空间·跨界创作的个人作品集。"
>

  <!-- ═══════════════ HERO CAROUSEL ═══════════════ -->
  <HeroCarousel slides={carouselSlides} client:load />

  <!-- ═══════════════ 关于我 — 左右分栏 + TOC 轮播导航 ═══════════════ -->
  <AboutSection />

  <!-- ═══════════════ PROJECT MAP — 作品地图卡片 ═══════════════ -->
  <section id="project-map" class="px-8 lg:px-12 pb-40 lg:pb-56 max-w-[1440px] mx-auto">
    <FadeIn client:visible>
      <p class="text-[0.6875rem] uppercase tracking-[0.2em] text-text-tertiary mb-6">
        Project Map
      </p>
    </FadeIn>
    <TextReveal
      as="h2"
      className="text-3xl lg:text-5xl font-medium tracking-[-0.02em] max-w-3xl mb-10"
      stagger={0.04}
      client:visible
      text="项目地图"
    />

    <div class="w-full h-[60vh] lg:h-[70vh]">
      <ProjectMap projects={mapProjects} client:only="react" />
    </div>

    <p class="text-xs text-text-tertiary mt-4 text-right">滚动缩放 · 点击标记查看项目详情</p>
  </section>

  <!-- ═══════════════ AWARDS — 学科竞赛荣誉 ═══════════════ -->
  <section id="awards" class="px-8 lg:px-12 pb-40 lg:pb-56 max-w-[1440px] mx-auto">
    <FadeIn client:visible>
      <p class="text-[0.6875rem] uppercase tracking-[0.2em] text-text-tertiary mb-6">
        Awards & Honors
      </p>
    </FadeIn>
    <TextReveal
      as="h2"
      className="text-3xl lg:text-5xl font-medium tracking-[-0.02em] max-w-3xl mb-10"
      stagger={0.04}
      client:visible
      text="学科竞赛"
    />
    <AwardsBento />
  </section>

  <!-- ═══════════════ SELECTED WORKS — 大幅间距·画册呼吸感 ═══════════════ -->
  <section id="works" class="px-8 lg:px-12 pb-48 lg:pb-64 max-w-[1440px] mx-auto">
    <FadeIn client:visible>
      <p class="text-[0.6875rem] uppercase tracking-[0.2em] text-text-tertiary mb-6">
        Selected Works
      </p>
      <p class="text-sm text-text-secondary mb-16 leading-relaxed max-w-xl">
        以下为近年完成的代表性建筑项目。每个项目都代表了对特定场地、文化与建造条件的独立回应。
      </p>
    </FadeIn>

    <TextReveal
      as="h2"
      className="text-3xl lg:text-5xl font-medium tracking-[-0.02em] max-w-3xl mb-12"
      stagger={0.04}
      client:visible
      text="建筑设计"
    />

    <div>
      {
        projects.map((project, i) => (
          <section class="mb-[100px] lg:mb-[280px] last:mb-0">
            <ProjectCard
              images={project.data.images}
              slug={project.slug}
              category={`${categoryLabel[project.data.category] || project.data.category} · ${project.data.location}`}
              title={project.data.title}
              year={project.data.year}
              status={statusLabel[project.data.status] || project.data.status}
              area={project.data.area || ''}
              brief={project.data.brief || ''}
              aspect={project.data.preview_aspect || '4/3'}
              columns={project.data.preview_columns || '7/5'}
              isEven={i % 2 === 0}
              client:visible
            />
          </section>
        ))
      }
    </div>
  </section>

  <!-- ═══════════════ ARTWORK ═══════════════ -->
  <section id="otherworks" class="border-t border-border pt-40 lg:pt-56">
    <div class="max-w-[1440px] mx-auto px-8 lg:px-12">
      <FadeIn client:visible>
        <p class="text-[0.6875rem] uppercase tracking-[0.2em] text-text-tertiary mb-6">
          otherworks
        </p>
      </FadeIn>

      <TextReveal
        as="h2"
        className="text-3xl lg:text-5xl font-medium tracking-[-0.02em] max-w-3xl mb-6"
        stagger={0.04}
        client:visible
        text="建筑之外"
      />

    </div>

    <OtherWorksFanOut items={fanOutItems} client:only="react" />
  </section>

</Base>
