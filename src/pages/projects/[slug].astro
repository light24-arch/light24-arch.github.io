---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import FadeIn from '../../components/FadeIn';
import ParallaxImage from '../../components/ParallaxImage';
import HorizontalGallery from '../../components/HorizontalGallery';

const categoryLabel: Record<string, string> = {
  'Residential': '住宅', 'Cultural': '文化', 'Commercial': '商业',
  'Public': '公共', 'Hotel': '酒店', 'Museum': '博物馆',
  'Mixed-Use': '混合功能', 'Masterplan': '总体规划', 'Concept': '概念设计',
};
const statusLabel: Record<string, string> = {
  'Built': '已建成', 'In Progress': '建设中', 'Competition': '竞赛', 'Concept': '概念', 'Design': '方案设计',
};

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((p) => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props;
const { data } = project;
const { Content } = await project.render();

const specs = [
  { label: '状态', value: statusLabel[data.status] || data.status },
  { label: '面积', value: data.area || '—' },
  { label: '角色', value: data.role || data.team || '—' },
];

function featureGrid(layout: string) {
  switch (layout) {
    case 'image-left':
      return {
        row: 'items-end',
        image: 'col-span-12 md:col-span-7',
        text: 'col-span-12 md:col-span-4 md:col-start-9 pb-12',
        imgOrder: '', textOrder: '',
      };
    case 'image-right':
      return {
        row: 'items-center',
        image: 'col-span-12 md:col-span-5 md:col-start-7 order-1 md:order-2',
        text: 'col-span-12 md:col-span-4 md:col-start-2 order-2 md:order-1 pt-12 md:pt-0',
        imgOrder: '', textOrder: '',
      };
    case 'image-center':
      return {
        row: 'items-start',
        image: 'col-span-12 md:col-span-6 md:col-start-3',
        text: 'col-span-12 md:col-span-3 md:col-start-10 mt-12 md:mt-24',
        imgOrder: '', textOrder: '',
      };
    case 'full-width':
      return {
        row: 'items-start',
        image: 'col-span-12',
        text: 'hidden',
        imgOrder: '', textOrder: '',
      };
    case 'image-right-7':
      return { row: 'items-end', image: 'col-span-12 md:col-span-7 md:col-start-6', text: 'col-span-12 md:col-span-4 md:col-start-2 pb-12' };
    case 'transition-5':
      return { row: 'items-start', image: 'col-span-12 md:col-span-5', text: 'hidden' };
    case 'transition-7':
      return { row: 'items-start', image: 'col-span-12 md:col-span-7', text: 'hidden' };
    case 'transition-6':
      return { row: 'items-start', image: 'col-span-12 md:col-span-6 md:col-start-4', text: 'hidden' };
    case 'closing-7':
      return { row: 'items-start', image: 'col-span-12 md:col-span-7', text: 'hidden' };
    case 'image-left-wide':
      return { row: 'items-end', image: 'col-span-12 md:col-span-8', text: 'col-span-12 md:col-span-3 md:col-start-10 pb-12' };
    case 'image-right-wide':
      return {
        row: 'items-start',
        image: 'col-span-12 md:col-span-8 md:col-start-5',
        text: 'col-span-12 md:col-span-3 md:col-start-1 md:row-start-1 mt-12 md:mt-24',
        imgOrder: '', textOrder: '',
      };
    case 'wide-transition':
      return {
        row: 'items-start',
        image: 'col-span-12 md:col-span-10 md:col-start-2',
        text: 'hidden',
        imgOrder: '', textOrder: '',
      };
    case 'transition':
      return {
        row: 'items-start',
        image: 'col-span-12 md:col-span-9 md:col-start-2',
        text: 'hidden',
        imgOrder: '', textOrder: '',
      };
    case 'wide':
      return {
        row: 'items-end',
        image: 'col-span-12 md:col-span-9',
        text: 'col-span-12 md:col-span-3 md:col-start-10 pb-8 mt-8 md:mt-0',
        imgOrder: '', textOrder: '',
      };
    default:
      return {
        row: 'items-start',
        image: 'col-span-12 md:col-span-6 md:col-start-3',
        text: 'col-span-12 md:col-span-3 md:col-start-10 mt-12 md:mt-24',
        imgOrder: '', textOrder: '',
      };
  }
}
---

<Base
  title={data.title}
  description={`${data.title} — ${data.location}，${data.year}。${categoryLabel[data.category] || data.category}项目。`}
  image={data.hero}
>

  <!-- ═══════════ 1. 顶部返回栏 ═══════════ -->
  <nav class="w-full px-6 md:px-12 py-8 pt-28 md:pt-32 max-w-[100rem] mx-auto">
    <a
      href="/"
      class="inline-flex items-center gap-2 text-sm font-medium tracking-widest uppercase hover:opacity-50 transition-opacity group"
    >
      <span class="group-hover:-translate-x-1 transition-transform duration-300">&larr;</span>
      返回作品列表
    </a>
  </nav>

  <!-- ═══════════ 2. Hero：项目信息 + 全屏头图 ═══════════ -->
  <header class="px-6 md:px-12 max-w-[100rem] mx-auto mb-32">
    <div class="mb-16">
      <p class="text-xs tracking-[0.2em] text-text-tertiary uppercase mb-4">
        {data.year} · {categoryLabel[data.category] || data.category} / {data.location}
      </p>
      <h1 class="text-6xl md:text-8xl font-bold tracking-tighter mb-12 text-text-primary">
        {data.title}
      </h1>
      <div class="hairline"></div>
      <div class="flex flex-col md:flex-row gap-8 md:gap-24 mt-6 text-sm text-text-tertiary uppercase tracking-widest">
        {specs.map((s) => (
          <div>
            <span class="block text-text-primary mb-1">{s.label}</span>
            {s.value}
          </div>
        ))}
      </div>
    </div>
    <!-- 全屏头图 · 保持原始比例 -->
    <div class="w-full">
      <img src={data.hero} alt={data.title} class="w-full h-auto block" />
    </div>
  </header>

  <!-- ═══════════ 3. 总体介绍 (Main Concept) ═══════════ -->
  {data.concept && (
    <section class="px-6 md:px-12 max-w-[90rem] mx-auto mb-48">
      <div class="grid grid-cols-12 gap-8">
        <div class="col-span-12 md:col-span-8 md:col-start-3 text-center">
          <p class="text-2xl md:text-4xl leading-snug font-light text-text-primary">
            {data.concept}
          </p>
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════ 4. 动态图文错落网格 ═══════════ -->
  {data.features.length > 0 && (
    <section class="px-6 md:px-12 max-w-[100rem] mx-auto space-y-32 md:space-y-64">
      {data.features.map((f) => {
        const g = featureGrid(f.layout);
        return (
          <div class={`grid grid-cols-12 gap-8 ${g.row}`}>
            <div class={`${g.image}`}>
              <img src={f.image} alt={f.title} class="w-full h-auto block" loading="lazy" />
            </div>
            {!['full-width','transition','wide-transition','transition-5','transition-6','transition-7','closing-7'].includes(f.layout) && (
              <div class={`${g.text}`}>
                <h2 class="text-xs tracking-[0.2em] text-text-tertiary uppercase mb-4 border-b border-border pb-2">
                  {f.number}. {f.label}
                </h2>
                <h3 class="text-3xl font-bold mb-6 tracking-tight text-text-primary">
                  {f.title}
                </h3>
                <p class="text-text-secondary leading-relaxed text-sm md:text-base">
                  {f.text}
                </p>
              </div>
            )}
          </div>
        );
      })}

      <!-- 全宽大图收尾 -->
      {data.closing_image && (
        <div class="grid grid-cols-12 gap-8 pt-16">
          <div class="col-span-12">
            <img src={data.closing_image} alt={`${data.title} — 收尾`} class="w-full h-auto block" loading="lazy" />
          </div>
        </div>
      )}
    </section>
  )}

  <!-- ═══════════ 5. 底部横向滑动图组 ═══════════ -->
  {data.gallery_images && data.gallery_images.length > 0 && (
    <section class="max-w-[100rem] mx-auto mt-32 md:mt-48 px-6 md:px-12">
      <div class="w-full md:w-8/12 mx-auto">
        <HorizontalGallery images={data.gallery_images} client:load />
      </div>
    </section>
  )}

  <!-- ═══════════ 6. 底部导航 ═══════════ -->
  <footer class="w-full border-t border-border mt-48 py-12 px-6 md:px-12 max-w-[100rem] mx-auto flex justify-between items-center">
    <div class="text-xs text-text-tertiary">&copy; {data.year} {data.title}</div>
    <a href="/" class="text-xs font-bold tracking-widest uppercase hover:opacity-50 transition-opacity">
      返回作品列表 &rarr;
    </a>
  </footer>

</Base>
